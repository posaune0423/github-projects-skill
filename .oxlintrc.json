{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "es2022": true,
    "node": true
  },
  "plugins": ["typescript"],
  "rules": {
    "no-unused-vars": "off",
    "@typescript-eslint/no-unused-vars": "warn",
    "no-console": "off",
    "eqeqeq": "error",
    "no-var": "error",
    "prefer-const": "warn"
  },
  "ignorePatterns": ["**/node_modules/**", "dist/**", "out/**", "coverage/**", ".vite/**"]
}
